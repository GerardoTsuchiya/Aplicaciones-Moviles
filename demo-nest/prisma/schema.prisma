generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model usuario {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}

model todo {
  id          Int     @id @default(autoincrement())
  titulo      String
  descripcion String?
  completado  Boolean @default(false)
}
